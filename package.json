{
  "name": "image-collector",
  "version": "2.0.0",
  "description": "图片搜集器 v2.0.0 - 快速扫描整理电脑图片，支持缩略图预览、收藏、分页和批量操作",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "build": "electron-builder --win"
  },
  "author": "ImageCollector",
  "license": "MIT",
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "electron": "^28.3.3",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "vite": "^6.2.0"
  },
  "dependencies": {
    "electron-log": "^5.2.4",
    "jsqr": "^1.4.0"
  },
  "build": {
    "appId": "com.imagecollector.app",
    "productName": "图片搜集器",
    "asar": true,
    "directories": {
      "output": "dist-new"
    },
    "files": [
      "src/**/*",
      "!src/**/*.map"
    ],
    "extraResources": [],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.png",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.exe"
    }
  }
}
